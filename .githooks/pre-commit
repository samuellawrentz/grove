#!/usr/bin/env bash
set -euo pipefail

# Unset git env vars that leak into subprocess calls during hook execution
unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE GIT_OBJECT_DIRECTORY GIT_ALTERNATE_OBJECT_DIRECTORIES

echo "==> cargo fmt"
cargo fmt

echo "==> cargo clippy"
cargo clippy -- -D warnings

echo "==> cargo test"
cargo test

echo "All checks passed."
